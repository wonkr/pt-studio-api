// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Trainer {
  id                  String               @id @default(uuid())
  name                String
  email               String               @unique
  passwordHash        String               @map("password_hash")
  createdAt           DateTime             @default(now()) @map("created_at")
  trainerExpenses     TrainerExpense[]
  members             Member[]
  sessionPasses       SessionPass[]
  memberships         Membership[]
  schedules           Schedule[]
  attendances         Attendance[]
  revenueRecognitions RevenueRecognition[]

  @@map("trainers")
}

model TrainerExpense {
  id        String          @id @default(uuid())
  trainer   Trainer         @relation(fields: [trainerId], references: [id])
  trainerId String          @map("trainer_id")
  category  ExpenseCategory
  amount    Decimal
  memo      String?
  paidAt    DateTime        @map("paid_at")
  createdAt DateTime        @default(now()) @map("created_at")

  @@map("trainer_expenses")
}

model Member {
  id                  String               @id @default(uuid())
  trainer             Trainer              @relation(fields: [trainerId], references: [id])
  trainerId           String               @map("trainer_id")
  name                String
  phoneNumber         String               @map("phone_number")
  createdAt           DateTime             @default(now()) @map("created_at")
  memberships         Membership[]
  attendances         Attendance[]
  schedules           Schedule[]
  revenueRecognitions RevenueRecognition[]

  @@map("members")
}

model SessionPass {
  id            String       @id @default(uuid())
  trainer       Trainer      @relation(fields: [trainerId], references: [id])
  trainerId     String       @map("trainer_id")
  name          String
  totalSessions Int          @map("total_sessions")
  price         Decimal
  validDays     Int          @map("valid_days")
  memberships   Membership[]

  @@unique([trainerId, name])
  @@map("session_passes")
}

model Membership {
  id                String        @id @default(uuid())
  trainer           Trainer       @relation(fields: [trainerId], references: [id])
  trainerId         String        @map("trainer_id")
  member            Member        @relation(fields: [memberId], references: [id])
  memberId          String        @map("member_id")
  sessionPass       SessionPass   @relation(fields: [sessionPassId], references: [id])
  sessionPassId     String        @map("session_pass_id")
  paymentType       PaymentType   @map("payment_type")
  paymentStatus     PaymentStatus @map("payment_status")
  paidAt            DateTime?     @map("paid_at")
  startedAt         DateTime?     @map("started_at")
  expiredAt         DateTime?     @map("expired_at")
  remainingSessions Int           @map("remaining_sessions")
  usedSessions      Int           @map("used_sessions")
  attendances       Attendance[]

  @@map("memberships")
}

model Attendance {
  id String @id @default(uuid())

  trainer            Trainer             @relation(fields: [trainerId], references: [id])
  trainerId          String              @map("trainer_id")
  member             Member              @relation(fields: [memberId], references: [id])
  memberId           String              @map("member_id")
  membership         Membership          @relation(fields: [membershipId], references: [id])
  membershipId       String              @map("membership_id")
  attendedAt         DateTime            @map("attended_at")
  revenueRecognition RevenueRecognition?

  @@map("attendances")
}

model Schedule {
  id        String         @id @default(uuid())
  trainer   Trainer        @relation(fields: [trainerId], references: [id])
  trainerId String         @map("trainer_id")
  member    Member         @relation(fields: [memberId], references: [id])
  memberId  String         @map("member_id")
  time      DateTime
  status    ScheduleStatus

  @@map("schedules")
}

model RevenueRecognition {
  id           String     @id @default(uuid())
  trainer      Trainer    @relation(fields: [trainerId], references: [id])
  trainerId    String     @map("trainer_id")
  member       Member     @relation(fields: [memberId], references: [id])
  memberId     String     @map("member_id")
  attendance   Attendance @relation(fields: [attendanceId], references: [id])
  attendanceId String     @unique @map("attendance_id")
  amount       Decimal
  recognizedAt DateTime   @map("recognized_at")

  @@map("revenue_recognitions")
}

enum ScheduleStatus {
  SCHEDULED
  CANCELED
  COMPLETED
}

enum ExpenseCategory {
  RENT
  UTILITY
  SUPPLY
  OTHER
}

enum PaymentType {
  CARD
  CASH
  TRANSFER
}

enum PaymentStatus {
  PAID
  PENDING
  REFUNDED
}
